# ======================================
# AISHOP Dashboard — Cấu hình môi trường
# ======================================
# Copy file này thành .env và điền thông tin

# Port server (mặc định: 3000)
PORT=3000

# ======================================
# TURSO CLOUD DATABASE (cho hosting/production)
# ======================================
# Bỏ comment 2 dòng dưới để sử dụng Turso Cloud
# Nếu không set, app sẽ dùng SQLite local (file data.db)

# TURSO_DATABASE_URL=libsql://your-database-name.turso.io
# TURSO_AUTH_TOKEN=your-auth-token-here

# ======================================
# HƯỚNG DẪN LẤY TURSO CREDENTIALS (MIỄN PHÍ)
# ======================================
# 1. Đăng ký tại: https://turso.tech (free, dùng GitHub login)
# 2. Cài Turso CLI:
#    Windows: irm https://get.tur.so/install.ps1 | iex
#    Mac/Linux: curl -sSfL https://get.tur.so/install.sh | bash
# 3. Đăng nhập CLI: turso auth login
# 4. Tạo database: turso db create aishop
# 5. Lấy URL: turso db show aishop --url
# 6. Lấy token: turso db tokens create aishop
# 7. Điền vào TURSO_DATABASE_URL và TURSO_AUTH_TOKEN ở trên
